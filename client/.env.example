# Copy this file to .env.local and fill in your CoinGecko Demo key.
#
# CoinGecko Demo tier key — server-only. Get one at:
# https://www.coingecko.com/en/developers/dashboard
COINGECKO_API_KEY=""

# SQLite database path (lives in .env; read by both the Prisma CLI and the Next runtime).
DATABASE_URL="file:./hoshi.db"
